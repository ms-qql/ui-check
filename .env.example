# UI-Check — Umgebungsvariablen (Vorlage)
#
# Kopieren nach .env (bereits in .gitignore) und Werte eintragen:
#   cp .env.example .env   &&   $EDITOR .env
# Laden vor einem Lauf:
#   set -a; . ./.env; set +a
#
# ALLE Bildquellen sind opt-in — ohne Key bleibt die Bild-Befüllung (PROJ-20)
# beim 0-€-Platzhalter-Verhalten. Nichts hier ist Pflicht.

# ── Stock-Bilder (PROJ-20, kostenlos) ───────────────────────────────────────
# Unsplash: der "Access Key" (Client-ID) aus der App — NICHT der Secret Key.
UNSPLASH_ACCESS_KEY=
# Pexels: der einzelne API-Key aus dem Konto.
PEXELS_API_KEY=

# ── KI-Bild-Generierung (PROJ-20, optional, Cents/Bild) ─────────────────────
# Genau einer reicht; Vorrang openai → fal → recraft (via IMAGES_FILL_GEN_PROVIDER erzwingbar).
OPENAI_API_KEY=
FAL_KEY=
RECRAFT_API_KEY=

# ── Branding-Logo (PROJ-3, optional) ────────────────────────────────────────
# Brandfetch-Client-ID für die Logo-API (sonst DOM-Fallback).
BRANDFETCH_CLIENT_ID=
