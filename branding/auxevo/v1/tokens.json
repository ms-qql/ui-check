{
  "$description": "Branding-Profil auxevo — Design-Tokens (DTCG). Aus /home/dev/tools/Hal/00 Context importiert.",
  "$meta": {
    "profile": "auxevo",
    "source": "Hal 00 Context",
    "mood": [
      "dark-first",
      "technical",
      "minimal",
      "teal"
    ]
  },
  "color": {
    "accent": {
      "$type": "color",
      "$value": "#0d9488",
      "$extensions": {
        "role": "brand-accent / CTA"
      }
    },
    "accent-hover": {
      "$type": "color",
      "$value": "#0891b2",
      "$extensions": {
        "role": "hover"
      }
    },
    "accent-active": {
      "$type": "color",
      "$value": "#0e7490",
      "$extensions": {
        "role": "active"
      }
    },
    "accent-soft": {
      "$type": "color",
      "$value": "#ccfbf1",
      "$extensions": {
        "role": "soft tint"
      }
    },
    "glow": {
      "$type": "color",
      "$value": "#5eead4",
      "$extensions": {
        "role": "highlight glow"
      }
    },
    "ink": {
      "$type": "color",
      "$value": "#0a0a0a",
      "$extensions": {
        "role": "canvas / dark background"
      }
    },
    "surface": {
      "$type": "color",
      "$value": "#171717",
      "$extensions": {
        "role": "surface"
      }
    },
    "surface-card": {
      "$type": "color",
      "$value": "#1f1f1f",
      "$extensions": {
        "role": "card surface"
      }
    },
    "text": {
      "$type": "color",
      "$value": "#fafafa",
      "$extensions": {
        "role": "on-dark text"
      }
    },
    "muted": {
      "$type": "color",
      "$value": "#a3a3a3",
      "$extensions": {
        "role": "secondary text"
      }
    },
    "muted-2": {
      "$type": "color",
      "$value": "#525252",
      "$extensions": {
        "role": "tertiary text / border text"
      }
    }
  },
  "font": {
    "sans": {
      "$type": "fontFamily",
      "$value": [
        "DM Sans",
        "system-ui",
        "sans-serif"
      ],
      "$extensions": {
        "source": "Bunny Fonts or self-hosted"
      }
    },
    "mono": {
      "$type": "fontFamily",
      "$value": [
        "JetBrains Mono",
        "ui-monospace",
        "monospace"
      ],
      "$extensions": {
        "role": "labels / code"
      }
    }
  },
  "radius": {
    "sm": {
      "$type": "dimension",
      "$value": "4px"
    },
    "md": {
      "$type": "dimension",
      "$value": "6px"
    },
    "lg": {
      "$type": "dimension",
      "$value": "8px"
    }
  }
}
