{
  "$description": "Branding-Profil meridian — Design-Tokens (DTCG). Abgeleitet aus meridian-nextjs-template.vercel.app (computed styles: fumadocs/shadcn-Neutral + rotes Signal, DM Sans / Space Grotesk / JetBrains Mono).",
  "$meta": {
    "profile": "meridian",
    "source": "meridian-nextjs-template.vercel.app (Next.js/fumadocs-Template, kommerziell)",
    "note": "Clean-Room-Nachbau. Nur Farb-/Font-/Radius-Rollen übernommen, kein proprietärer Code/Assets.",
    "mood": ["dark", "editorial", "technical", "blueprint", "developer-tool", "saas"]
  },
  "color": {
    "paper":   { "$type": "color", "$value": "#ffffff", "$extensions": { "role": "light-surface / inverted-card" } },
    "ink":     { "$type": "color", "$value": "#0a0a0a", "$extensions": { "role": "page-background (dark-default)" } },
    "ink-soft":{ "$type": "color", "$value": "#16161a", "$extensions": { "role": "raised-dark-card / hover" } },
    "muted":   { "$type": "color", "$value": "#8f8f8f", "$extensions": { "role": "secondary-text / two-tone-headline-gray" } },
    "surface": { "$type": "color", "$value": "#f5f5f5", "$extensions": { "role": "light-secondary (inside inverted cards)" } },
    "line":    { "$type": "color", "$value": "#e5e5e5", "$extensions": { "role": "border in light areas (dark areas use paper/NN)" } },
    "accent":      { "$type": "color", "$value": "#e5484d", "$extensions": { "role": "signal (SEV badge, budget-burn, live-dot)" } },
    "accent-soft": { "$type": "color", "$value": "#ff8a5c", "$extensions": { "role": "warm accent (iridescent CTA-glow gradient)" } },
    "sand":        { "$type": "color", "$value": "#b9b09c", "$extensions": { "role": "warm neutral (rarely used)" } }
  },
  "font": {
    "sans":    { "$type": "fontFamily", "$value": ["DM Sans", "ui-sans-serif", "system-ui", "sans-serif"], "$extensions": { "role": "body", "source": "self-hosted (OFL)" } },
    "display": { "$type": "fontFamily", "$value": ["Space Grotesk", "ui-sans-serif", "system-ui", "sans-serif"], "$extensions": { "role": "display headlines / big numbers", "source": "self-hosted (OFL)" } },
    "mono":    { "$type": "fontFamily", "$value": ["JetBrains Mono", "ui-monospace", "monospace"], "$extensions": { "role": "dispatch labels / spec cards / receipts (uppercase, tracked)", "source": "self-hosted (OFL)" } }
  },
  "radius": {
    "base": { "$type": "dimension", "$value": "0.625rem" }
  },
  "type": {
    "display": { "$extensions": { "font": "Space Grotesk", "weight": 500, "tracking": "-0.02em", "leading": 1.0, "clamp": "clamp(2.25rem, 5vw, 4rem)" } },
    "hero":    { "$extensions": { "font": "Space Grotesk", "weight": 500, "clamp": "clamp(2.75rem, 7vw, 5.5rem)" } },
    "two-tone":{ "$extensions": { "note": "Headlines splitten: erster Teil text-paper, zweiter Teil text-muted." } },
    "mono-label": { "$extensions": { "font": "JetBrains Mono", "transform": "uppercase", "tracking": "0.18em", "size": "0.68rem" } },
    "body": { "$extensions": { "font": "DM Sans", "size": "1.05rem", "leading": "relaxed", "color": "muted" } }
  }
}
