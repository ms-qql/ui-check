{
  "$description": "Branding-Profil verdict — Design-Tokens (DTCG). Abgeleitet aus verdict-nextjs-template.vercel.app (computed styles, shadcn/ui-Default + Amber-Akzent).",
  "$meta": {
    "profile": "verdict",
    "source": "verdict-nextjs-template.vercel.app (shadcnblocks, kommerziell)",
    "note": "Clean-Room-Nachbau. Nur Farb-/Font-/Radius-Rollen übernommen, kein proprietärer Code/Assets.",
    "mood": ["premium", "editorial", "legal", "agency", "trust"]
  },
  "color": {
    "paper":   { "$type": "color", "$value": "#ffffff", "$extensions": { "role": "page-background" } },
    "ink":     { "$type": "color", "$value": "#0a0a0a", "$extensions": { "role": "foreground / dark-section" } },
    "ink-soft":{ "$type": "color", "$value": "#171717", "$extensions": { "role": "dark-hover" } },
    "muted":   { "$type": "color", "$value": "#737373", "$extensions": { "role": "secondary-text" } },
    "surface": { "$type": "color", "$value": "#f5f5f5", "$extensions": { "role": "raised-surface / inputs" } },
    "line":    { "$type": "color", "$value": "#e3ddd6", "$extensions": { "role": "border / divider" } },
    "accent":      { "$type": "color", "$value": "#c87f2c", "$extensions": { "role": "brand-accent / ring" } },
    "accent-soft": { "$type": "color", "$value": "#e8a95c", "$extensions": { "role": "accent-light / gradient" } },
    "sand":        { "$type": "color", "$value": "#c9b191", "$extensions": { "role": "warm-stat-tile" } }
  },
  "font": {
    "sans": { "$type": "fontFamily", "$value": ["Geist", "ui-sans-serif", "system-ui", "sans-serif"], "$extensions": { "role": "display + body", "source": "self-hosted (OFL)" } },
    "mono": { "$type": "fontFamily", "$value": ["Geist Mono", "ui-monospace", "monospace"], "$extensions": { "role": "eyebrows / labels (uppercase, tracked)" } }
  },
  "radius": {
    "base": { "$type": "dimension", "$value": "0.625rem" }
  },
  "type": {
    "display": { "$extensions": { "weight": 500, "tracking": "-0.02em", "leading": 1.02, "clamp": "clamp(2rem, 4.6vw, 3.5rem)" } },
    "hero":    { "$extensions": { "weight": 500, "clamp": "clamp(2.75rem, 6vw, 5rem)" } },
    "mono-label": { "$extensions": { "transform": "uppercase", "tracking": "0.18em", "size": "0.68rem" } },
    "body": { "$extensions": { "size": "1.05rem", "leading": "relaxed", "color": "muted" } }
  }
}
